# Dora-Agent local Docker development env template.
# Defaults assume Go services run on macOS and dependencies are exposed by Docker.
# Copy this file to .env.local only for local-only overrides or secrets.
# Do not commit real secrets.

APP_ENV=local
APP_NAME=dora-agent
LOG_LEVEL=debug

# Local machine
HOST_OS=macos
LOCAL_DOCKER=true

# Service ports
FRONTEND_DEV_PORT=3000
AGENT_HTTP_PORT=18080
BUSINESS_KITEX_PORT=19001
BUSINESS_HTTP_PORT=19080

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=dora
POSTGRES_PASSWORD=dora_local_password
POSTGRES_SSLMODE=disable
BUSINESS_DATABASE_NAME=dora_business
AGENT_DATABASE_NAME=dora_agent
BUSINESS_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_business?sslmode=disable
AGENT_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_agent?sslmode=disable

# etcd
ETCD_ENDPOINTS=http://127.0.0.1:2379
ETCD_NAMESPACE=/dora/local
DORA_CONFIG_SOURCE=env
DORA_CONFIG_ETCD_TIMEOUT=2s
BUSINESS_SERVICE_NAME=dora.business
BUSINESS_HOSTPORTS=127.0.0.1:19001
AGENT_SERVICE_NAME=dora.agent

# Kitex
KITEX_REGISTRY=etcd
KITEX_TIMEOUT_MS=3000

# Gin / Business API adapter
BUSINESS_HTTP_ENABLED=true
BUSINESS_HTTP_ADDR=0.0.0.0:19080
PUBLIC_WEB_BASE_URL=http://localhost:3000

# Business admin bootstrap. Use password hash or secret reference only.
ADMIN_BOOTSTRAP_ACCOUNT=admin
ADMIN_BOOTSTRAP_PASSWORD_HASH=
ADMIN_BOOTSTRAP_CREDENTIAL_SECRET_REF=

# Gin / Agent API
AGENT_HTTP_ADDR=0.0.0.0:18080
AGENT_SSE_ENABLED=true
AGENT_WS_ENABLED=true
AGENT_SSE_HEARTBEAT_SECONDS=15
AGENT_EVENT_REPLAY_PAGE_SIZE=10
AGENT_EVENT_REPLAY_MAX_PAGE_SIZE=100

# Agent runtime config
AGENT_CONFIG_SOURCE=postgres
AGENT_DEFAULT_CONFIG_VERSION=local-dev
AGENT_TOOL_ALLOWLIST=
AGENT_MEMORY_ENABLED=true
AGENT_TOOL_DEFAULT_TIMEOUT_MS=120000
AGENT_SAFETY_POLICY_VERSION=local-v1
AGENT_GENERATION_QUEUE=inline
AGENT_GENERATION_REDIS_ADDR=127.0.0.1:6379
AGENT_GENERATION_REDIS_PASSWORD=
AGENT_GENERATION_REDIS_DB=0
AGENT_GENERATION_REDIS_LIST_KEY=dora:agent:generation_jobs
AGENT_GENERATION_WORKERS=1
AGENT_GENERATION_RECOVERY_STALE_AFTER=5m

# DeepSeek runtime. Real API key must be set in .env.local only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=2048

# Local TLS placeholder values. Fill real Volcengine TLS values in .env.local only.
VOLC_TLS_ENDPOINT=
VOLC_TLS_REGION=
VOLC_TLS_ACCESS_KEY_ID=
VOLC_TLS_ACCESS_KEY_SECRET=
VOLC_TLS_PROJECT_ID=
VOLC_TLS_TOPIC_ID=

# Local/fake TOS-compatible object storage. Fill real AK/SK in .env.local only.
TOS_ENDPOINT=127.0.0.1:9000
TOS_BUCKET=dora-local
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=local
TOS_BASE_URL=http://localhost/tos
TOS_REQUEST_TIMEOUT=30s
TOS_CONNECT_TIMEOUT=10s

# Local SMS placeholder. Real provider secrets and template identifiers go in .env.local only.
VOLCENGINE_SMS_ACCESS_KEY_ID=
VOLCENGINE_SMS_SECRET_ACCESS_KEY=
VOLCENGINE_SMS_ACCOUNT=
VOLCENGINE_SMS_SIGN=
VOLCENGINE_SMS_TEMPLATE_ID=
VOLCENGINE_SMS_CODE_PARAM=code
VOLCENGINE_SMS_USER_EXT_CODE=
VOLCENGINE_SMS_REGION=local
VOLCENGINE_SMS_HOST=http://127.0.0.1:19190
VOLCENGINE_SMS_TAG_PREFIX=dora-local-login

# External providers / AIGC local placeholders
MODEL_PROVIDER=local
MODEL_API_KEY=
IMAGE_PROVIDER=local
VIDEO_PROVIDER=local
MUSIC_PROVIDER=local

# Security
JWT_SECRET=local-dev-only-change-me
SECRET_ENCRYPTION_KEY_REF=local-dev-secret-key-ref
CORS_ALLOWED_ORIGINS=http://localhost:3000
