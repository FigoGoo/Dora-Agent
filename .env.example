# Dora-Agent local Docker development env template.
# Defaults match the connection information used by cc-yr and codex/agent-core-refactor.
# Copy to .env.local for local-only overrides and real secrets.

APP_ENV=local
APP_NAME=dora-agent
LOG_LEVEL=debug
AGENT_HTTP_ADDR=:18080

# PostgreSQL exposed by docker-compose.local.yml
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=dora
POSTGRES_PASSWORD=dora_local_password
POSTGRES_SSLMODE=disable
BUSINESS_DATABASE_NAME=dora_business
AGENT_DATABASE_NAME=dora_agent
BUSINESS_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_business?sslmode=disable
AGENT_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_agent?sslmode=disable

# Redis exposed by docker-compose.local.yml
AGENT_GENERATION_REDIS_ADDR=127.0.0.1:6379
AGENT_GENERATION_REDIS_PASSWORD=
AGENT_GENERATION_REDIS_DB=0
AGENT_GENERATION_REDIS_LIST_KEY=dora:agent:generation_jobs
AGENT_RUNTIME_REDIS_MODE=redis
AGENT_RUNTIME_REDIS_ADDR=127.0.0.1:6379
AGENT_RUNTIME_REDIS_PASSWORD=
AGENT_RUNTIME_REDIS_DB=0
AGENT_RUNTIME_REDIS_STREAM_MAX_LEN=1000

# The local acceptance profile uses DeepSeek for Agent/Capability inference and
# the real Image2 provider for image generation. Keep both real keys in
# .env.local only; never commit them.
DORA_DEEPSEEK_API_KEY=
DORA_DEEPSEEK_MODEL=deepseek-chat
DORA_DEEPSEEK_BASE_URL=https://api.deepseek.com
DORA_IMAGE2_API_KEY=

# Local media profile: Image2 remains real and its b64_json result is persisted
# below DORA_LOCAL_ASSET_DIR. Seedance can write a deterministic placeholder,
# Audio writes a demo WAV, and Assembly writes a JSON manifest. No real video or
# audio synthesis, assembly, or transcoding is required for local acceptance.
# The router serves local assets from DORA_LOCAL_ASSET_BASE_URL, so TOS is not
# required for this profile.
DORA_LOCAL_DEMO=true
DORA_LOCAL_ASSET_DIR=.local/aigc-assets
DORA_LOCAL_ASSET_BASE_URL=/api/aigc/local-assets

# Optional real Seedance override. Leave it empty to keep the local placeholder
# path while still exercising the complete Worker/Finalization flow.
DORA_SEEDANCE_API_KEY=

# Optional non-local object storage. These settings are ignored while
# DORA_LOCAL_ASSET_DIR is non-empty; they are not needed for the local demo.
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=dora-public
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_BASE_URL=https://tos.doraigc.com
TOS_REQUEST_TIMEOUT=30s
TOS_CONNECT_TIMEOUT=10s
