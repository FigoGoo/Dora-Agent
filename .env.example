# Dora 三 Module 本地联调配置模板。
# 复制为 .env.local 后只在本机修改；生产环境不得复用这些开发凭据。

DORA_ENV=local

# 预置正常登录路径使用的本地 Smoke 账号；不得复制到共享或生产环境。
DORA_SMOKE_USER_EMAIL=smoke.user@example.test
DORA_SMOKE_USER_PASSWORD=dora-local-smoke-password-v1
DORA_SMOKE_USER_DISPLAY_NAME=本地冒烟用户

# Local Compose PostgreSQL 初始化密码。
DORA_POSTGRES_ADMIN_PASSWORD=dora_local_admin_password
DORA_BUSINESS_DB_PASSWORD=dora_local_business_password
DORA_AGENT_DB_PASSWORD=dora_local_agent_password
DORA_WORKER_DB_PASSWORD=dora_local_worker_password
DORA_POSTGRES_PORT=15432
DORA_REDIS_PORT=16379
DORA_ETCD_PORT=12379

# Business Service。
BUSINESS_INSTANCE_ID=business-local-1
BUSINESS_ADVERTISED_ADDRESS=host.docker.internal:18081
BUSINESS_HTTP_ADDR=:18081
BUSINESS_HTTP_HEADER_TIMEOUT=5s
BUSINESS_HTTP_READ_TIMEOUT=15s
BUSINESS_HTTP_WRITE_TIMEOUT=30s
BUSINESS_HTTP_IDLE_TIMEOUT=60s
BUSINESS_HTTP_MAX_HEADER_BYTES=1048576
# 必须替换为本地独有、32-64 bytes 密钥的标准 Base64，不得复用到其他环境。
BUSINESS_AUTH_CSRF_SECRET_BASE64=cmVwbGFjZV93aXRoX2xvY2FsX2NzcmZfc2VjcmV0XzMy
BUSINESS_AUTH_SESSION_IDLE_TTL=30m
BUSINESS_AUTH_SESSION_ABSOLUTE_TTL=24h
BUSINESS_AUTH_COOKIE_NAME=dora_session
BUSINESS_AUTH_COOKIE_DOMAIN=
BUSINESS_AUTH_COOKIE_SECURE=false
BUSINESS_AUTH_COOKIE_SAME_SITE=lax
BUSINESS_AUTH_MAX_REQUEST_BODY_BYTES=4096
BUSINESS_AUTH_MAX_CONCURRENT_SESSIONS=5
BUSINESS_AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
BUSINESS_AUTH_LOGIN_RATE_LIMIT_WINDOW=15m
BUSINESS_AUTH_LOGIN_RATE_LIMIT_TIMEOUT=500ms
# 以下密钥只用于一次性本地联调模板；共享环境必须分别生成并由 Secret Manager 注入。
BUSINESS_PROJECT_PROMPT_KEY_BASE64=YnVzaW5lc3MtcHJvamVjdC1wcm9tcHQta2V5LXYxISE=
BUSINESS_PROJECT_PROMPT_KEY_VERSION=local-business-project-v1
BUSINESS_PROJECT_MAX_REQUEST_BODY_BYTES=409600
BUSINESS_PROJECT_MAX_OUTBOX_ATTEMPTS=5
BUSINESS_AGENT_RPC_CONNECT_TIMEOUT=2s
BUSINESS_AGENT_RPC_REQUEST_TIMEOUT=3s
BUSINESS_AGENT_SESSION_RPC_AUTH_SECRET_BASE64=YnVzaW5lc3MtYWdlbnQtcnBjLWF1dGgta2V5LXYxISE=
# Browser 仍只访问 Business；以下配置只用于 Business BFF 调用 Agent HTTP。
BUSINESS_AGENT_HTTP_BASE_URL=http://127.0.0.1:18082
BUSINESS_AGENT_HTTP_REQUEST_TIMEOUT=5s
BUSINESS_AGENT_HTTP_ASSERTION_KEY_VERSION=local-business-agent-http-v1
BUSINESS_AGENT_HTTP_ASSERTION_SECRET_BASE64=bG9jYWwtYnVzaW5lc3MtYWdlbnQtaHR0cC1rZXktdjE=
BUSINESS_AGENT_HTTP_ASSERTION_TTL=30s
BUSINESS_PROJECT_DISPATCH_LEASE_DURATION=15s
BUSINESS_PROJECT_DISPATCH_RETRY_DELAY=1s
BUSINESS_PROJECT_DISPATCH_POLL_INTERVAL=250ms
BUSINESS_RPC_LISTEN_ADDR=:19081
# foundation-smoke 会把该模板主机名替换为本机非回环 IPv4；直接或跨机运行时必须改为消费者真实可达地址。
BUSINESS_RPC_ADVERTISED_ADDRESS=host.docker.internal:19081
BUSINESS_RPC_READ_WRITE_TIMEOUT=10s
BUSINESS_RPC_MAX_CONN_IDLE_TIME=5m
BUSINESS_DATABASE_URL=postgres://dora_business_app:dora_local_business_password@127.0.0.1:15432/dora_business?sslmode=disable
BUSINESS_CONTRACT_DATABASE_URL=postgres://dora_business_app:dora_local_business_password@127.0.0.1:15432/dora_business_test?sslmode=disable
BUSINESS_DB_MAX_OPEN_CONNS=20
BUSINESS_DB_MAX_IDLE_CONNS=10
BUSINESS_DB_CONN_MAX_LIFETIME=30m
BUSINESS_DB_CONN_MAX_IDLE_TIME=5m
BUSINESS_DB_PING_TIMEOUT=3s
BUSINESS_REDIS_ADDR=127.0.0.1:16379
BUSINESS_REDIS_PASSWORD=
BUSINESS_REDIS_DB=0
BUSINESS_REDIS_PING_TIMEOUT=3s
BUSINESS_ETCD_ENDPOINTS=127.0.0.1:12379
BUSINESS_ETCD_DIAL_TIMEOUT=5s
BUSINESS_ETCD_LEASE_TTL=15s
BUSINESS_SHUTDOWN_TIMEOUT=20s

# Agent Service。W0 已接 Session RPC 与内容保护，模型和 Graph Tool 仍未接线。
AGENT_INSTANCE_ID=agent-local-1
AGENT_ADVERTISED_ADDRESS=host.docker.internal:18082
AGENT_HTTP_ADDR=:18082
AGENT_HTTP_HEADER_TIMEOUT=5s
AGENT_HTTP_READ_TIMEOUT=15s
AGENT_HTTP_WRITE_TIMEOUT=30s
AGENT_HTTP_IDLE_TIMEOUT=60s
AGENT_HTTP_MAX_HEADER_BYTES=1048576
AGENT_HTTP_ASSERTION_ACTIVE_KEY_VERSION=local-business-agent-http-v1
AGENT_HTTP_ASSERTION_ACTIVE_SECRET_BASE64=bG9jYWwtYnVzaW5lc3MtYWdlbnQtaHR0cC1rZXktdjE=
AGENT_HTTP_ASSERTION_PREVIOUS_KEY_VERSION=
AGENT_HTTP_ASSERTION_PREVIOUS_SECRET_BASE64=
AGENT_HTTP_ASSERTION_MAX_CLOCK_SKEW=5s
AGENT_HTTP_ASSERTION_REPLAY_TIMEOUT=500ms
AGENT_RPC_LISTEN_ADDR=:19082
# foundation-smoke 会把该模板主机名替换为本机非回环 IPv4；直接或跨机运行时必须改为消费者真实可达地址。
AGENT_RPC_ADVERTISED_ADDRESS=host.docker.internal:19082
AGENT_RPC_READ_WRITE_TIMEOUT=10s
AGENT_RPC_MAX_CONN_IDLE_TIME=5m
AGENT_SESSION_RPC_AUTH_SECRET_BASE64=YnVzaW5lc3MtYWdlbnQtcnBjLWF1dGgta2V5LXYxISE=
AGENT_SESSION_RPC_AUTH_MAX_CLOCK_SKEW=30s
AGENT_DATABASE_URL=postgres://dora_agent_app:dora_local_agent_password@127.0.0.1:15432/dora_agent?sslmode=disable
AGENT_CONTRACT_DATABASE_URL=postgres://dora_agent_app:dora_local_agent_password@127.0.0.1:15432/dora_agent_test?sslmode=disable
AGENT_DB_MAX_OPEN_CONNS=20
AGENT_DB_MAX_IDLE_CONNS=10
AGENT_DB_CONN_MAX_LIFETIME=30m
AGENT_DB_CONN_MAX_IDLE_TIME=5m
AGENT_DB_PING_TIMEOUT=3s
AGENT_REDIS_ADDR=127.0.0.1:16379
AGENT_REDIS_PASSWORD=
AGENT_REDIS_DB=1
AGENT_REDIS_PING_TIMEOUT=3s
AGENT_ETCD_ENDPOINTS=127.0.0.1:12379
AGENT_ETCD_DIAL_TIMEOUT=5s
AGENT_ETCD_LEASE_TTL=15s
AGENT_BUSINESS_RPC_CONNECT_TIMEOUT=2s
AGENT_BUSINESS_RPC_REQUEST_TIMEOUT=3s
AGENT_BUSINESS_RPC_STARTUP_TIMEOUT=15s
AGENT_BUSINESS_RPC_PROBE_INTERVAL=250ms
# 仅供本地联调；共享/生产环境必须由 Secret Manager 注入不同的 Base64 32 字节密钥并轮换版本。
AGENT_CONTENT_KEY_BASE64=YWdlbnQtY29udGVudC1zdG9yYWdlLWtleS12MSEhISE=
AGENT_CONTENT_KEY_VERSION=local-agent-content-v1
AGENT_CONTENT_PREVIOUS_KEY_VERSION=
AGENT_CONTENT_PREVIOUS_KEY_BASE64=
AGENT_WORKSPACE_MAX_MESSAGES=100
AGENT_WORKSPACE_MAX_INPUTS=100
AGENT_SSE_BATCH_SIZE=100
AGENT_SSE_POLL_INTERVAL=250ms
AGENT_SSE_HEARTBEAT_INTERVAL=5s
AGENT_SSE_MAX_CONNECTION_DURATION=20s
AGENT_SSE_FRAME_WRITE_TIMEOUT=3s
AGENT_SSE_MAX_EVENT_BYTES=65536
AGENT_SSE_MAX_CONNECTIONS=100
AGENT_SSE_MAX_CONNECTIONS_PER_USER=5
AGENT_SSE_MAX_CONNECTIONS_PER_SESSION=3
AGENT_SHUTDOWN_TIMEOUT=20s

# Business Worker。本阶段只验证执行器资源边界，Job 契约尚未接线。
WORKER_INSTANCE_ID=worker-local-1
WORKER_HTTP_ADDR=:18083
WORKER_HTTP_HEADER_TIMEOUT=5s
WORKER_HTTP_READ_TIMEOUT=10s
WORKER_HTTP_WRITE_TIMEOUT=10s
WORKER_HTTP_IDLE_TIMEOUT=60s
WORKER_HTTP_MAX_HEADER_BYTES=1048576
WORKER_DATABASE_URL=postgres://dora_worker_app:dora_local_worker_password@127.0.0.1:15432/dora_worker?sslmode=disable
WORKER_CONTRACT_DATABASE_URL=postgres://dora_worker_app:dora_local_worker_password@127.0.0.1:15432/dora_worker_test?sslmode=disable
WORKER_DB_MAX_OPEN_CONNS=20
WORKER_DB_MAX_IDLE_CONNS=10
WORKER_DB_CONN_MAX_LIFETIME=30m
WORKER_DB_CONN_MAX_IDLE_TIME=5m
WORKER_DB_PING_TIMEOUT=3s
WORKER_REDIS_ADDR=127.0.0.1:16379
WORKER_REDIS_PASSWORD=
WORKER_REDIS_DB=2
WORKER_REDIS_PING_TIMEOUT=3s
WORKER_ETCD_ENDPOINTS=127.0.0.1:12379
WORKER_ETCD_DIAL_TIMEOUT=5s
WORKER_CONCURRENCY=8
WORKER_CLAIM_BATCH_SIZE=8
WORKER_POLL_INTERVAL=1s
WORKER_LEASE_TTL=30s
WORKER_HEARTBEAT_INTERVAL=5s
WORKER_ATTEMPT_TIMEOUT=2m
WORKER_MAX_ATTEMPTS=3
WORKER_SHUTDOWN_TIMEOUT=30s

# M2/M4 外部 Adapter 预留。当前 Runtime 不读取这些变量。
DORA_DEEPSEEK_API_KEY=
DORA_DEEPSEEK_MODEL=deepseek-chat
DORA_DEEPSEEK_BASE_URL=https://api.deepseek.com
DORA_IMAGE2_API_KEY=
DORA_SEEDANCE_API_KEY=
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=dora-public
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_BASE_URL=https://tos.doraigc.com
