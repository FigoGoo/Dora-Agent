# Dora-Agent local development env template
# Copy this file to .env.local and fill local-only values.
# Do not commit real secrets.

APP_ENV=local
APP_NAME=dora-agent
LOG_LEVEL=debug

# Local machine
HOST_OS=macos
LOCAL_DOCKER=true

# Service ports
FRONTEND_DEV_PORT=3000
AGENT_HTTP_PORT=18080
BUSINESS_KITEX_PORT=19001

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=dora
POSTGRES_PASSWORD=dora_local_password
POSTGRES_SSLMODE=disable
BUSINESS_DATABASE_NAME=dora_business
AGENT_DATABASE_NAME=dora_agent
BUSINESS_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_business?sslmode=disable
AGENT_DATABASE_URL=postgres://dora:dora_local_password@127.0.0.1:5432/dora_agent?sslmode=disable

# etcd
ETCD_ENDPOINTS=http://127.0.0.1:2379
ETCD_NAMESPACE=/dora/local
BUSINESS_SERVICE_NAME=dora.business
AGENT_SERVICE_NAME=dora.agent

# Kitex
KITEX_REGISTRY=etcd
KITEX_TIMEOUT_MS=3000

# Gin / Agent API
AGENT_HTTP_ADDR=0.0.0.0:18080
AGENT_SSE_ENABLED=true
AGENT_WS_ENABLED=true

# Agent runtime config
AGENT_CONFIG_SOURCE=postgres
AGENT_DEFAULT_CONFIG_VERSION=local-dev
AGENT_TOOL_ALLOWLIST=
AGENT_MEMORY_ENABLED=false

# Volcengine TLS placeholder values. Fill in .env.local only.
VOLC_TLS_ENDPOINT=
VOLC_TLS_REGION=
VOLC_TLS_ACCESS_KEY_ID=
VOLC_TLS_ACCESS_KEY_SECRET=
VOLC_TLS_PROJECT_ID=
VOLC_TLS_TOPIC_ID=

# Volcengine TOS public bucket. Secret values must be filled in .env.local only.
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=dora-public
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_BASE_URL=https://tos.doraigc.com
TOS_REQUEST_TIMEOUT=30s
TOS_CONNECT_TIMEOUT=10s

# Volcengine SMS. Secret values and production template identifiers go in .env.local only.
VOLCENGINE_SMS_ACCESS_KEY_ID=
VOLCENGINE_SMS_SECRET_ACCESS_KEY=
VOLCENGINE_SMS_ACCOUNT=
VOLCENGINE_SMS_SIGN=
VOLCENGINE_SMS_TEMPLATE_ID=
VOLCENGINE_SMS_CODE_PARAM=code
VOLCENGINE_SMS_USER_EXT_CODE=
VOLCENGINE_SMS_REGION=cn-north-1
VOLCENGINE_SMS_HOST=sms.volcengineapi.com
VOLCENGINE_SMS_TAG_PREFIX=dora-login

# External providers / AIGC placeholders
MODEL_PROVIDER=
MODEL_API_KEY=
IMAGE_PROVIDER=
VIDEO_PROVIDER=
MUSIC_PROVIDER=

# Security
JWT_SECRET=local-dev-only-change-me
CORS_ALLOWED_ORIGINS=http://localhost:3000
