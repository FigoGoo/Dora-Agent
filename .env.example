DORA_WORKER_MEDIA_RETRY_BASE_DELAY=1s
DORA_WORKER_MEDIA_RETRY_MAX_DELAY=30s

# M2/M4 外部 Adapter 预留。当前 Runtime 不读取这些变量。
DORA_DEEPSEEK_API_KEY=
DORA_DEEPSEEK_MODEL=deepseek-chat
