# Dora 三 Module 本地联调配置模板。
# 复制为 .env.local 后只在本机修改；生产环境不得复用这些开发凭据。

DORA_ENV=local

# 预置正常登录路径使用的本地 Smoke 账号；不得复制到共享或生产环境。
DORA_SMOKE_USER_EMAIL=smoke.user@example.test
DORA_SMOKE_USER_PASSWORD=dora-local-smoke-password-v1
DORA_SMOKE_USER_DISPLAY_NAME=本地冒烟用户

# Local Compose PostgreSQL 初始化密码。
DORA_POSTGRES_ADMIN_PASSWORD=dora_local_admin_password
DORA_BUSINESS_DB_PASSWORD=dora_local_business_password
DORA_AGENT_DB_PASSWORD=dora_local_agent_password
DORA_WORKER_DB_PASSWORD=dora_local_worker_password
DORA_POSTGRES_PORT=15432
DORA_REDIS_PORT=16379
DORA_ETCD_PORT=12379

# Business Service。
BUSINESS_INSTANCE_ID=business-local-1
# 一键基本功能统一 Profile；默认关闭，只有 local + 全 loopback 联调时允许精确启用。
DORA_BUSINESS_RUNTIME_PROFILE=
# 六工具媒体扩展必须依附上面的统一 Profile；对象根必须是已存在的绝对 0700 非符号链接目录。
DORA_BUSINESS_MEDIA_RUNTIME_PROFILE=
DORA_BUSINESS_MEDIA_OBJECT_ROOT=
BUSINESS_ADVERTISED_ADDRESS=host.docker.internal:18081
BUSINESS_HTTP_ADDR=:18081
BUSINESS_HTTP_HEADER_TIMEOUT=5s
BUSINESS_HTTP_READ_TIMEOUT=15s
BUSINESS_HTTP_WRITE_TIMEOUT=30s
BUSINESS_HTTP_IDLE_TIMEOUT=60s
BUSINESS_HTTP_MAX_HEADER_BYTES=1048576
# 必须替换为本地独有、32-64 bytes 密钥的标准 Base64，不得复用到其他环境。
BUSINESS_AUTH_CSRF_SECRET_BASE64=cmVwbGFjZV93aXRoX2xvY2FsX2NzcmZfc2VjcmV0XzMy
BUSINESS_AUTH_SESSION_IDLE_TTL=30m
BUSINESS_AUTH_SESSION_ABSOLUTE_TTL=24h
BUSINESS_AUTH_COOKIE_NAME=dora_session
BUSINESS_AUTH_COOKIE_DOMAIN=
BUSINESS_AUTH_COOKIE_SECURE=false
BUSINESS_AUTH_COOKIE_SAME_SITE=lax
BUSINESS_AUTH_MAX_REQUEST_BODY_BYTES=4096
BUSINESS_AUTH_MAX_CONCURRENT_SESSIONS=5
BUSINESS_AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
BUSINESS_AUTH_LOGIN_RATE_LIMIT_WINDOW=15m
BUSINESS_AUTH_LOGIN_RATE_LIMIT_TIMEOUT=500ms
# 以下密钥只用于一次性本地联调模板；共享环境必须分别生成并由 Secret Manager 注入。
BUSINESS_PROJECT_PROMPT_KEY_BASE64=YnVzaW5lc3MtcHJvamVjdC1wcm9tcHQta2V5LXYxISE=
BUSINESS_PROJECT_PROMPT_KEY_VERSION=local-business-project-v1
BUSINESS_PROJECT_PROMPT_PREVIOUS_KEY_BASE64=
BUSINESS_PROJECT_PROMPT_PREVIOUS_KEY_VERSION=
BUSINESS_PROJECT_MAX_REQUEST_BODY_BYTES=409600
BUSINESS_PROJECT_MAX_OUTBOX_ATTEMPTS=5
# 显式 QuickCreate v2 默认关闭；只有确认所有 Agent 实例都支持同一契约与不小于以下 limits 后才可同时开启。
BUSINESS_PROJECT_SKILL_SNAPSHOT_V2_ENABLED=false
BUSINESS_AGENT_SESSION_V2_CAPABILITY_CONFIRMED=false
BUSINESS_SKILL_SNAPSHOT_LIMITS_PROFILE_VERSION=session_skill_snapshot_limits.v1
BUSINESS_SKILL_SNAPSHOT_MAX_ITEMS=16
BUSINESS_SKILL_SNAPSHOT_MAX_RUNTIME_CONTENT_BYTES_PER_ITEM=65536
BUSINESS_SKILL_SNAPSHOT_MAX_TOTAL_RUNTIME_CONTENT_BYTES=262144
BUSINESS_SKILL_SNAPSHOT_MAX_METADATA_BYTES=131072
BUSINESS_SKILL_SNAPSHOT_MAX_EXAMPLES_PER_ITEM=16
BUSINESS_SKILL_SNAPSHOT_MAX_STARTER_PROMPTS_PER_ITEM=16
BUSINESS_SKILL_SNAPSHOT_MAX_OUTBOX_PLAINTEXT_BYTES=2097152
BUSINESS_AGENT_RPC_CONNECT_TIMEOUT=2s
BUSINESS_AGENT_RPC_REQUEST_TIMEOUT=3s
BUSINESS_AGENT_SESSION_RPC_AUTH_SECRET_BASE64=YnVzaW5lc3MtYWdlbnQtcnBjLWF1dGgta2V5LXYxISE=
# Browser 仍只访问 Business；以下配置只用于 Business BFF 调用 Agent HTTP。
BUSINESS_AGENT_HTTP_BASE_URL=http://127.0.0.1:18082
BUSINESS_AGENT_HTTP_REQUEST_TIMEOUT=5s
BUSINESS_AGENT_HTTP_ASSERTION_KEY_VERSION=local-business-agent-http-v1
BUSINESS_AGENT_HTTP_ASSERTION_SECRET_BASE64=bG9jYWwtYnVzaW5lc3MtYWdlbnQtaHR0cC1rZXktdjE=
BUSINESS_AGENT_HTTP_ASSERTION_TTL=30s
# 素材分析输入 Foundation RPC 预览默认关闭，仅允许 DORA_ENV=local 显式开启。
DORA_BUSINESS_ASSET_ANALYSIS_PREVIEW_ENABLED=false
# analyze_materials Runtime 的同源 BFF 写入口默认关闭；开启时还必须同时开启上面的 Evidence Preview。
DORA_BUSINESS_ANALYZE_MATERIALS_RUNTIME_ENABLED=false
DORA_BUSINESS_PLAN_STORYBOARD_RUNTIME_ENABLED=false
# write_prompts Storyboard Preview 单 Tool Runtime 默认关闭，并与其他 Preview Runtime 互斥。
DORA_BUSINESS_WRITE_PROMPTS_RUNTIME_ENABLED=false
DORA_BUSINESS_WRITE_PROMPTS_RUNTIME_PROFILE=write_prompts.runtime.v2preview1
# 启用任一 Storyboard/Prompt Runtime 时，BUSINESS_HTTP_ADDR/BUSINESS_RPC_LISTEN_ADDR 必须显式绑定 127.0.0.1，对应 advertised 地址必须逐字相等；Agent HTTP、PostgreSQL、Redis、etcd 也必须为 loopback。
BUSINESS_PROJECT_DISPATCH_LEASE_DURATION=15s
BUSINESS_PROJECT_DISPATCH_RETRY_DELAY=1s
BUSINESS_PROJECT_DISPATCH_POLL_INTERVAL=250ms
BUSINESS_RPC_LISTEN_ADDR=:19081
# foundation-smoke 会把该模板主机名替换为本机非回环 IPv4；直接或跨机运行时必须改为消费者真实可达地址。
BUSINESS_RPC_ADVERTISED_ADDRESS=host.docker.internal:19081
BUSINESS_RPC_READ_WRITE_TIMEOUT=10s
BUSINESS_RPC_MAX_CONN_IDLE_TIME=5m
BUSINESS_DATABASE_URL=postgres://dora_business_app:dora_local_business_password@127.0.0.1:15432/dora_business?sslmode=disable
BUSINESS_CONTRACT_DATABASE_URL=postgres://dora_business_app:dora_local_business_password@127.0.0.1:15432/dora_business_test?sslmode=disable
BUSINESS_DB_MAX_OPEN_CONNS=20
BUSINESS_DB_MAX_IDLE_CONNS=10
BUSINESS_DB_CONN_MAX_LIFETIME=30m
BUSINESS_DB_CONN_MAX_IDLE_TIME=5m
BUSINESS_DB_PING_TIMEOUT=3s
BUSINESS_REDIS_ADDR=127.0.0.1:16379
BUSINESS_REDIS_PASSWORD=
BUSINESS_REDIS_DB=0
BUSINESS_REDIS_PING_TIMEOUT=3s
BUSINESS_ETCD_ENDPOINTS=127.0.0.1:12379
BUSINESS_ETCD_DIAL_TIMEOUT=5s
BUSINESS_ETCD_LEASE_TTL=15s
BUSINESS_SHUTDOWN_TIMEOUT=20s

# Agent Service。本地模板显式开启 V1 plan_creation_spec 开发预览；共享/生产环境默认必须关闭。
AGENT_INSTANCE_ID=agent-local-1
# 一键基本功能统一 Profile；启用时下方五套隔离 Runtime 开关必须全部为 false。
DORA_AGENT_RUNTIME_PROFILE=
# 六工具媒体扩展必须依附上面的统一 Profile，并只允许调用 loopback Business 内部端点。
DORA_AGENT_MEDIA_RUNTIME_PROFILE=
DORA_AGENT_MEDIA_BUSINESS_BASE_URL=
DORA_AGENT_MEDIA_BUSINESS_CALL_TIMEOUT=5s
DORA_AGENT_MEDIA_MAX_RESPONSE_BYTES=65536
AGENT_ADVERTISED_ADDRESS=host.docker.internal:18082
AGENT_HTTP_ADDR=:18082
AGENT_HTTP_HEADER_TIMEOUT=5s
AGENT_HTTP_READ_TIMEOUT=15s
AGENT_HTTP_WRITE_TIMEOUT=30s
AGENT_HTTP_IDLE_TIMEOUT=60s
AGENT_HTTP_MAX_HEADER_BYTES=1048576
AGENT_HTTP_ASSERTION_ACTIVE_KEY_VERSION=local-business-agent-http-v1
AGENT_HTTP_ASSERTION_ACTIVE_SECRET_BASE64=bG9jYWwtYnVzaW5lc3MtYWdlbnQtaHR0cC1rZXktdjE=
AGENT_HTTP_ASSERTION_PREVIOUS_KEY_VERSION=
AGENT_HTTP_ASSERTION_PREVIOUS_SECRET_BASE64=
AGENT_HTTP_ASSERTION_MAX_CLOCK_SKEW=5s
AGENT_HTTP_ASSERTION_REPLAY_TIMEOUT=500ms
AGENT_RPC_LISTEN_ADDR=:19082
# foundation-smoke 会把该模板主机名替换为本机非回环 IPv4；直接或跨机运行时必须改为消费者真实可达地址。
AGENT_RPC_ADVERTISED_ADDRESS=host.docker.internal:19082
AGENT_RPC_READ_WRITE_TIMEOUT=10s
AGENT_RPC_MAX_CONN_IDLE_TIME=5m
AGENT_SESSION_RPC_AUTH_SECRET_BASE64=YnVzaW5lc3MtYWdlbnQtcnBjLWF1dGgta2V5LXYxISE=
AGENT_SESSION_RPC_AUTH_MAX_CLOCK_SKEW=30s
AGENT_DATABASE_URL=postgres://dora_agent_app:dora_local_agent_password@127.0.0.1:15432/dora_agent?sslmode=disable
AGENT_CONTRACT_DATABASE_URL=postgres://dora_agent_app:dora_local_agent_password@127.0.0.1:15432/dora_agent_test?sslmode=disable
AGENT_DB_MAX_OPEN_CONNS=20
AGENT_DB_MAX_IDLE_CONNS=10
AGENT_DB_CONN_MAX_LIFETIME=30m
AGENT_DB_CONN_MAX_IDLE_TIME=5m
AGENT_DB_PING_TIMEOUT=3s
AGENT_REDIS_ADDR=127.0.0.1:16379
AGENT_REDIS_PASSWORD=
AGENT_REDIS_DB=1
AGENT_REDIS_PING_TIMEOUT=3s
AGENT_ETCD_ENDPOINTS=127.0.0.1:12379
AGENT_ETCD_DIAL_TIMEOUT=5s
AGENT_ETCD_LEASE_TTL=15s
AGENT_BUSINESS_RPC_CONNECT_TIMEOUT=2s
AGENT_BUSINESS_RPC_REQUEST_TIMEOUT=3s
AGENT_BUSINESS_RPC_STARTUP_TIMEOUT=15s
AGENT_BUSINESS_RPC_PROBE_INTERVAL=250ms
DORA_AGENT_PLAN_SPEC_PREVIEW_ENABLED=true
# Preview Runtime 只在上述本地开关启用时构造；所有 ReAct、Worker、Lease 与恢复预算均显式有界。
DORA_AGENT_PLAN_SPEC_PREVIEW_MAX_ITERATIONS=4
DORA_AGENT_PLAN_SPEC_PREVIEW_PROCESSOR_CONCURRENCY=2
DORA_AGENT_PLAN_SPEC_PREVIEW_POLL_INTERVAL=500ms
DORA_AGENT_PLAN_SPEC_PREVIEW_LEASE_DURATION=30s
DORA_AGENT_PLAN_SPEC_PREVIEW_HEARTBEAT_INTERVAL=10s
DORA_AGENT_PLAN_SPEC_PREVIEW_RETRY_DELAY=1s
DORA_AGENT_PLAN_SPEC_PREVIEW_RECOVERY_DELAY=2s
DORA_AGENT_PLAN_SPEC_PREVIEW_MAX_ATTEMPTS=5
DORA_AGENT_PLAN_SPEC_PREVIEW_MAX_BUSINESS_RESENDS=3
# 通用 user_message 方案 A 默认关闭，且与 CreationSpec Preview、Analyze Materials Runtime 互斥。
# 本地联调方案 A 时先把 DORA_AGENT_PLAN_SPEC_PREVIEW_ENABLED 改为 false，再显式开启本开关。
DORA_AGENT_USER_MESSAGE_RUNTIME_ENABLED=false
DORA_AGENT_USER_MESSAGE_RUNTIME_PROFILE=user_message.runtime.v2preview1
DORA_AGENT_USER_MESSAGE_PROCESSOR_CONCURRENCY=2
DORA_AGENT_USER_MESSAGE_POLL_INTERVAL=500ms
DORA_AGENT_USER_MESSAGE_LEASE_DURATION=30s
DORA_AGENT_USER_MESSAGE_HEARTBEAT_INTERVAL=10s
DORA_AGENT_USER_MESSAGE_RETRY_DELAY=1s
DORA_AGENT_USER_MESSAGE_RECOVERY_DELAY=2s
DORA_AGENT_USER_MESSAGE_MAX_ATTEMPTS=5
DORA_AGENT_USER_MESSAGE_MAX_OUTPUT_BYTES=4096
# analyze_materials 单 Tool Runtime 默认关闭；启用前必须关闭上面另外两个 Processor，且只允许 local。
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_ENABLED=false
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_PROFILE=analyze_materials.runtime.v2preview1
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_PROCESSOR_CONCURRENCY=2
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_POLL_INTERVAL=500ms
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_LEASE_DURATION=30s
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_HEARTBEAT_INTERVAL=10s
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_RETRY_DELAY=1s
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_RECOVERY_DELAY=2s
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_MAX_ATTEMPTS=5
DORA_AGENT_ANALYZE_MATERIALS_RUNTIME_MAX_OUTPUT_BYTES=65536
# plan_storyboard 单 Tool Runtime 默认关闭；启用前必须关闭其余三个 Processor，且只允许 local。
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_ENABLED=false
# 启用上项时，AGENT_HTTP_ADDR/AGENT_RPC_LISTEN_ADDR 必须显式绑定 127.0.0.1，对应 advertised 地址必须逐字相等；PostgreSQL、Redis、etcd 也必须为 loopback。
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_PROFILE=plan_storyboard.runtime.v2preview1
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_PROCESSOR_CONCURRENCY=2
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_POLL_INTERVAL=500ms
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_LEASE_DURATION=30s
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_HEARTBEAT_INTERVAL=10s
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_RETRY_DELAY=1s
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_RECOVERY_DELAY=2s
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_MAX_ATTEMPTS=5
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_MAX_OUTPUT_BYTES=65536
DORA_AGENT_PLAN_STORYBOARD_RUNTIME_MAX_BUSINESS_RESENDS=1
# write_prompts 单 Tool Runtime 默认关闭；启用前必须关闭其余 Preview Processor，且只允许 local loopback。
DORA_AGENT_WRITE_PROMPTS_RUNTIME_ENABLED=false
DORA_AGENT_WRITE_PROMPTS_RUNTIME_PROFILE=write_prompts.runtime.v2preview1
DORA_AGENT_WRITE_PROMPTS_RUNTIME_PROCESSOR_CONCURRENCY=2
DORA_AGENT_WRITE_PROMPTS_RUNTIME_POLL_INTERVAL=500ms
DORA_AGENT_WRITE_PROMPTS_RUNTIME_LEASE_DURATION=30s
DORA_AGENT_WRITE_PROMPTS_RUNTIME_HEARTBEAT_INTERVAL=10s
DORA_AGENT_WRITE_PROMPTS_RUNTIME_RETRY_DELAY=1s
DORA_AGENT_WRITE_PROMPTS_RUNTIME_RECOVERY_DELAY=2s
DORA_AGENT_WRITE_PROMPTS_RUNTIME_MAX_ATTEMPTS=5
DORA_AGENT_WRITE_PROMPTS_RUNTIME_MAX_OUTPUT_BYTES=131072
DORA_AGENT_WRITE_PROMPTS_RUNTIME_MAX_TARGETS=96
DORA_AGENT_WRITE_PROMPTS_RUNTIME_DEFAULT_OUTPUT_LANGUAGE=zh-CN
DORA_AGENT_WRITE_PROMPTS_RUNTIME_MAX_BUSINESS_RESENDS=1
# 仅供本地联调；共享/生产环境必须由 Secret Manager 注入不同的 Base64 32 字节密钥并轮换版本。
AGENT_CONTENT_KEY_BASE64=YWdlbnQtY29udGVudC1zdG9yYWdlLWtleS12MSEhISE=
AGENT_CONTENT_KEY_VERSION=local-agent-content-v1
AGENT_CONTENT_PREVIOUS_KEY_VERSION=
AGENT_CONTENT_PREVIOUS_KEY_BASE64=
# Agent 接收上限必须大于或等于 Business Producer 有效上限；Public Tool 在 W1 强制为零。
AGENT_SKILL_SNAPSHOT_LIMITS_PROFILE_VERSION=session_skill_snapshot_limits.v1
AGENT_SKILL_SNAPSHOT_MAX_ITEMS=16
AGENT_SKILL_SNAPSHOT_MAX_RUNTIME_CONTENT_BYTES_PER_ITEM=65536
AGENT_SKILL_SNAPSHOT_MAX_TOTAL_RUNTIME_CONTENT_BYTES=262144
AGENT_SKILL_SNAPSHOT_MAX_METADATA_BYTES=131072
AGENT_SKILL_SNAPSHOT_MAX_EXAMPLES_PER_ITEM=16
AGENT_SKILL_SNAPSHOT_MAX_STARTER_PROMPTS_PER_ITEM=16
AGENT_SKILL_SNAPSHOT_MAX_ALLOWED_GRAPH_TOOL_KEYS_PER_ITEM=6
AGENT_SKILL_SNAPSHOT_MAX_PUBLIC_TOOL_REFS_PER_ITEM=0
AGENT_SKILL_SNAPSHOT_MAX_RPC_REQUEST_BYTES=2097152
AGENT_SKILL_SNAPSHOT_MAX_OUTBOX_PLAINTEXT_BYTES=2097152
AGENT_WORKSPACE_MAX_MESSAGES=100
AGENT_WORKSPACE_MAX_INPUTS=100
AGENT_SSE_BATCH_SIZE=100
AGENT_SSE_POLL_INTERVAL=250ms
AGENT_SSE_HEARTBEAT_INTERVAL=5s
AGENT_SSE_MAX_CONNECTION_DURATION=20s
AGENT_SSE_FRAME_WRITE_TIMEOUT=3s
# Prompt Preview 最大 128KiB Card 还需 workspace.event.v1 Envelope 余量；本地模板固定 256KiB。
AGENT_SSE_MAX_EVENT_BYTES=262144
AGENT_SSE_MAX_CONNECTIONS=100
AGENT_SSE_MAX_CONNECTIONS_PER_USER=5
AGENT_SSE_MAX_CONNECTIONS_PER_SESSION=3
AGENT_SHUTDOWN_TIMEOUT=20s

# Business Worker。媒体 Profile 默认关闭；启用后从 Agent 专用 View/Function 领取 Job，
# 使用纯 Go 生成确定性 PNG，以固定 argv 的 ffmpeg 生成 MP4、ffprobe 验证，并通过 Business 完成资产 Finalize。
WORKER_INSTANCE_ID=worker-local-1
WORKER_HTTP_ADDR=127.0.0.1:18083
WORKER_HTTP_HEADER_TIMEOUT=5s
WORKER_HTTP_READ_TIMEOUT=10s
WORKER_HTTP_WRITE_TIMEOUT=10s
WORKER_HTTP_IDLE_TIMEOUT=60s
WORKER_HTTP_MAX_HEADER_BYTES=1048576
WORKER_DATABASE_URL=postgres://dora_worker_app:dora_local_worker_password@127.0.0.1:15432/dora_worker?sslmode=disable
WORKER_CONTRACT_DATABASE_URL=postgres://dora_worker_app:dora_local_worker_password@127.0.0.1:15432/dora_worker_test?sslmode=disable
WORKER_DB_MAX_OPEN_CONNS=20
WORKER_DB_MAX_IDLE_CONNS=10
WORKER_DB_CONN_MAX_LIFETIME=30m
WORKER_DB_CONN_MAX_IDLE_TIME=5m
WORKER_DB_PING_TIMEOUT=3s
WORKER_REDIS_ADDR=127.0.0.1:16379
WORKER_REDIS_PASSWORD=
WORKER_REDIS_DB=2
WORKER_REDIS_PING_TIMEOUT=3s
WORKER_ETCD_ENDPOINTS=127.0.0.1:12379
WORKER_ETCD_DIAL_TIMEOUT=5s
WORKER_CONCURRENCY=8
WORKER_CLAIM_BATCH_SIZE=8
WORKER_POLL_INTERVAL=1s
WORKER_LEASE_TTL=30s
WORKER_HEARTBEAT_INTERVAL=5s
WORKER_ATTEMPT_TIMEOUT=2m
WORKER_MAX_ATTEMPTS=3
WORKER_SHUTDOWN_TIMEOUT=30s
# 六工具媒体扩展；对象根必须与 Business 使用同一个绝对 0700 非符号链接目录。
DORA_WORKER_MEDIA_RUNTIME_PROFILE=
DORA_WORKER_MEDIA_OBJECT_ROOT=
# 使用 dora_worker_app 凭据连接 Agent 数据库，仅允许访问媒体 Claim View/Function。
DORA_WORKER_AGENT_CONSUMER_DSN=
DORA_WORKER_AGENT_DB_MAX_OPEN_CONNS=4
DORA_WORKER_AGENT_DB_MAX_IDLE_CONNS=2
DORA_WORKER_AGENT_DB_CONN_MAX_LIFETIME=10m
DORA_WORKER_AGENT_DB_CONN_MAX_IDLE_TIME=2m
DORA_WORKER_AGENT_DB_PING_TIMEOUT=3s
DORA_WORKER_BUSINESS_BASE_URL=
DORA_WORKER_FFMPEG_PATH=
DORA_WORKER_FFPROBE_PATH=
DORA_WORKER_MEDIA_AGENT_CALL_TIMEOUT=2s
DORA_WORKER_MEDIA_BUSINESS_CALL_TIMEOUT=5s
DORA_WORKER_MEDIA_MAX_RESPONSE_BYTES=65536
DORA_WORKER_MEDIA_MAX_PNG_BYTES=2097152
