{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/skill/skill-version.v1.schema.json",
  "title": "SkillVersion.v1",
  "type": "object",
  "required": [
    "schema_version",
    "skill_version_id",
    "skill_id",
    "version",
    "status",
    "runtime_spec_digest",
    "pricing_policy_digest",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "skill_version.v1"
    },
    "skill_version_id": {
      "type": "string",
      "pattern": "^skv_[A-Za-z0-9_\\-]+$"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^skill_[A-Za-z0-9_\\-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "reviewing",
        "rejected",
        "published",
        "deprecated",
        "removed"
      ]
    },
    "runtime_spec_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "pricing_policy_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "submitted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
