{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/skill/skill-pricing-policy.v1.schema.json",
  "title": "SkillPricingPolicy.v1",
  "type": "object",
  "required": [
    "schema_version",
    "pricing_policy_id",
    "skill_id",
    "skill_version",
    "pricing_model",
    "usage_credits",
    "value_delivered_stage",
    "pricing_policy_digest",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "skill_pricing_policy.v1"
    },
    "pricing_policy_id": {
      "type": "string",
      "pattern": "^spp_[A-Za-z0-9_\\-]+$"
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version": {
      "type": "string"
    },
    "pricing_model": {
      "type": "string",
      "enum": [
        "free",
        "fixed_per_use"
      ]
    },
    "usage_credits": {
      "type": "integer",
      "minimum": 0
    },
    "value_delivered_stage": {
      "type": "string",
      "enum": [
        "board_ready",
        "storyboard_ready",
        "asset_ready"
      ]
    },
    "pricing_policy_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
