{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/skill/skill-usage-record.v1.schema.json",
  "title": "SkillUsageRecord.v1",
  "type": "object",
  "required": [
    "schema_version",
    "usage_id",
    "run_id",
    "listing_id",
    "skill_id",
    "skill_version",
    "pricing_policy_digest",
    "skill_usage_digest",
    "usage_status",
    "charge_status",
    "refund_status",
    "settlement_status",
    "estimated_credits",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "skill_usage_record.v1"
    },
    "usage_id": {
      "type": "string",
      "pattern": "^susage_[A-Za-z0-9_\\-]+$"
    },
    "run_id": {
      "type": "string"
    },
    "listing_id": {
      "type": "string"
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version": {
      "type": "string"
    },
    "pricing_policy_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "skill_usage_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "usage_status": {
      "type": "string",
      "enum": [
        "confirmation_required",
        "confirmation_declined",
        "cancelled",
        "expired",
        "frozen",
        "running",
        "value_delivered",
        "charged",
        "settlement_pending",
        "released",
        "refund_pending",
        "refunded",
        "refund_rejected",
        "failed"
      ]
    },
    "charge_status": {
      "type": "string",
      "enum": [
        "not_frozen",
        "frozen",
        "charged",
        "released",
        "failed"
      ]
    },
    "refund_status": {
      "type": "string",
      "enum": [
        "none",
        "refund_requested",
        "refund_reviewing",
        "refund_approved",
        "refund_rejected",
        "refund_reversed"
      ]
    },
    "settlement_status": {
      "type": "string",
      "enum": [
        "pending_hold",
        "eligible",
        "settling",
        "settled",
        "reversed",
        "frozen",
        "failed"
      ]
    },
    "estimated_credits": {
      "type": "integer",
      "minimum": 0
    },
    "credit_hold_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "value_delivered_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
