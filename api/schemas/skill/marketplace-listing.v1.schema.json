{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/skill/marketplace-listing.v1.schema.json",
  "title": "MarketplaceListing.v1",
  "type": "object",
  "required": [
    "schema_version",
    "listing_id",
    "skill_id",
    "skill_version_id",
    "status",
    "pricing_policy_digest",
    "published_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "marketplace_listing.v1"
    },
    "listing_id": {
      "type": "string",
      "pattern": "^listing_[A-Za-z0-9_\\-]+$"
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_listing_review",
        "listed",
        "unlisted",
        "suspended",
        "removed"
      ]
    },
    "pricing_policy_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "published_by": {
      "type": "string"
    },
    "listed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
