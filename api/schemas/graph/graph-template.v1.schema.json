{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/graph/graph-template.v1.schema.json",
  "title": "GraphTemplate.v1",
  "type": "object",
  "required": [
    "schema_version",
    "graph_template_id",
    "name",
    "version",
    "graph_type",
    "skill_level",
    "entry_node",
    "terminal_nodes",
    "nodes",
    "edges",
    "template_digest",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "graph_template.v1"
    },
    "graph_template_id": {
      "type": "string",
      "pattern": "^gtemplate_[A-Za-z0-9_\\-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
    },
    "graph_type": {
      "type": "string",
      "enum": [
        "generic_creation",
        "system_skill",
        "marketplace_skill"
      ]
    },
    "skill_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3"
      ]
    },
    "entry_node": {
      "type": "string"
    },
    "terminal_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/GraphNode"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/GraphEdge"
      }
    },
    "template_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "GraphNode": {
      "type": "object",
      "required": [
        "node_id",
        "node_type",
        "display_name"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "node_type": {
          "type": "string",
          "enum": [
            "brief_parser",
            "clarifier",
            "llm",
            "board_writer",
            "router",
            "gate",
            "recommendation",
            "summarizer",
            "interrupt"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "config_digest": {
          "$ref": "../common/digest.schema.json"
        }
      },
      "additionalProperties": false
    },
    "GraphEdge": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "condition": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
