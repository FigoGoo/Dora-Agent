{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/graph/graph-checkpoint.v1.schema.json",
  "title": "GraphCheckpoint.v1",
  "type": "object",
  "required": [
    "schema_version",
    "checkpoint_id",
    "graph_plan_id",
    "run_id",
    "node_id",
    "checkpoint_type",
    "status",
    "state_digest",
    "resumable",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "graph_checkpoint.v1"
    },
    "checkpoint_id": {
      "type": "string",
      "pattern": "^gchk_[A-Za-z0-9_\\-]+$"
    },
    "graph_plan_id": {
      "type": "string",
      "pattern": "^gplan_[A-Za-z0-9_\\-]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string"
    },
    "checkpoint_type": {
      "type": "string",
      "enum": [
        "interrupt",
        "resume",
        "node_completed",
        "error_boundary"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resumed",
        "expired",
        "closed"
      ]
    },
    "state_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "resumable": {
      "type": "boolean"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
