{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/common/state-enum-registry.schema.json",
  "title": "StateEnumRegistry.v1",
  "type": "object",
  "$defs": {
    "RunStatus": {
      "type": "string",
      "enum": [
        "created",
        "routing",
        "planning",
        "waiting_input",
        "waiting_confirmation",
        "freezing",
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "BoardStatus": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "editing",
        "approved",
        "generating",
        "completed",
        "archived"
      ]
    },
    "GraphPlanStatus": {
      "type": "string",
      "enum": [
        "compiled",
        "running",
        "waiting_input",
        "waiting_confirmation",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "ToolPlanStatus": {
      "type": "string",
      "enum": [
        "draft",
        "estimated",
        "confirmation_required",
        "confirmed",
        "frozen",
        "queued",
        "running",
        "partially_completed",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "ToolTaskStatus": {
      "type": "string",
      "enum": [
        "pending",
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "released"
      ]
    },
    "SkillVersionStatus": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "reviewing",
        "rejected",
        "published",
        "deprecated",
        "removed"
      ]
    },
    "MarketplaceListingStatus": {
      "type": "string",
      "enum": [
        "draft",
        "pending_listing_review",
        "listed",
        "unlisted",
        "suspended",
        "removed"
      ]
    },
    "SkillUsageStatus": {
      "type": "string",
      "enum": [
        "confirmation_required",
        "confirmation_declined",
        "cancelled",
        "expired",
        "frozen",
        "running",
        "value_delivered",
        "charged",
        "settlement_pending",
        "released",
        "refund_pending",
        "refunded",
        "refund_rejected",
        "failed"
      ]
    },
    "SkillUsageChargeStatus": {
      "type": "string",
      "enum": [
        "not_frozen",
        "frozen",
        "charged",
        "released",
        "failed"
      ]
    },
    "SkillUsageRefundStatus": {
      "type": "string",
      "enum": [
        "none",
        "refund_requested",
        "refund_reviewing",
        "refund_approved",
        "refund_rejected",
        "refund_reversed"
      ]
    },
    "SettlementStatus": {
      "type": "string",
      "enum": [
        "pending_hold",
        "eligible",
        "settling",
        "settled",
        "reversed",
        "frozen",
        "failed"
      ]
    },
    "InstallationStatus": {
      "type": "string",
      "enum": [
        "installed",
        "disabled",
        "removed",
        "upgrade_required"
      ]
    },
    "InstallationUpgradeStatus": {
      "type": "string",
      "enum": [
        "none",
        "available",
        "manual_confirmation_required",
        "confirmed",
        "skipped",
        "failed"
      ]
    },
    "RefundCaseStatus": {
      "type": "string",
      "enum": [
        "refund_requested",
        "refund_reviewing",
        "refund_approved",
        "refund_rejected",
        "refund_reversed",
        "settlement_adjusted"
      ]
    }
  },
  "examples": [
    {
      "RunStatus": "running",
      "SkillUsageStatus": "confirmation_required",
      "MarketplaceListingStatus": "listed"
    }
  ]
}
