{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/common/ids.schema.json",
  "title": "CommonIds.v1",
  "type": "object",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-:.]*$"
    },
    "run_id": {
      "$ref": "#/$defs/id"
    },
    "session_id": {
      "$ref": "#/$defs/id"
    },
    "project_id": {
      "$ref": "#/$defs/id"
    },
    "space_id": {
      "$ref": "#/$defs/id"
    },
    "listing_id": {
      "$ref": "#/$defs/id"
    },
    "usage_id": {
      "$ref": "#/$defs/id"
    },
    "trace_id": {
      "$ref": "#/$defs/id"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    }
  }
}
