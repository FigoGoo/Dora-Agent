{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/router/creative-guide-output.v1.schema.json",
  "title": "CreativeGuideOutput.v1",
  "type": "object",
  "required": [
    "schema_version",
    "guide_id",
    "session_id",
    "suggested_prompts",
    "supported_output_types",
    "default_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "creative_guide_output.v1"
    },
    "guide_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "suggested_prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prompt_id",
          "label",
          "text"
        ],
        "properties": {
          "prompt_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "output_type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "supported_output_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
