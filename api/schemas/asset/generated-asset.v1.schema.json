{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/asset/generated-asset.v1.schema.json",
  "title": "GeneratedAsset.v1",
  "type": "object",
  "required": [
    "schema_version",
    "asset_id",
    "project_id",
    "run_id",
    "tool_task_id",
    "resource_type",
    "status",
    "tos_object_key",
    "asset_digest",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "generated_asset.v1"
    },
    "asset_id": {
      "type": "string",
      "pattern": "^asset_[A-Za-z0-9_\\-]+$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_task_id": {
      "type": "string",
      "pattern": "^ttask_[A-Za-z0-9_\\-]+$"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "image",
        "video",
        "audio",
        "text",
        "multimodal"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "committed",
        "failed",
        "skipped"
      ]
    },
    "tos_object_key": {
      "type": "string"
    },
    "preview_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "asset_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
