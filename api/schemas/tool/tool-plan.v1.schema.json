{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/tool/tool-plan.v1.schema.json",
  "title": "ToolPlan.v1",
  "type": "object",
  "required": [
    "schema_version",
    "tool_plan_id",
    "run_id",
    "board_id",
    "board_version",
    "graph_plan_id",
    "status",
    "items",
    "estimated_credits",
    "currency",
    "tool_plan_digest",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "tool_plan.v1"
    },
    "tool_plan_id": {
      "type": "string",
      "pattern": "^tpl_[A-Za-z0-9_\\-]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "board_id": {
      "type": "string",
      "pattern": "^board_[A-Za-z0-9_\\-]+$"
    },
    "board_version": {
      "type": "integer",
      "minimum": 1
    },
    "graph_plan_id": {
      "type": "string",
      "pattern": "^gplan_[A-Za-z0-9_\\-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "estimated",
        "confirmation_required",
        "confirmed",
        "frozen",
        "queued",
        "running",
        "partially_completed",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ToolPlanItem"
      }
    },
    "estimated_credits": {
      "type": "integer",
      "minimum": 0
    },
    "currency": {
      "const": "credits"
    },
    "confirmation_required": {
      "type": "boolean",
      "default": true
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "tool_plan_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "ToolPlanItem": {
      "type": "object",
      "required": [
        "tool_plan_item_id",
        "tool_id",
        "tool_version",
        "resource_type",
        "quantity",
        "estimated_credits",
        "input_digest"
      ],
      "properties": {
        "tool_plan_item_id": {
          "type": "string",
          "pattern": "^tpi_[A-Za-z0-9_\\-]+$"
        },
        "tool_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_version": {
          "type": "string",
          "minLength": 1
        },
        "resource_type": {
          "type": "string",
          "enum": [
            "image",
            "video",
            "audio",
            "text",
            "multimodal"
          ]
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "estimated_credits": {
          "type": "integer",
          "minimum": 0
        },
        "input_digest": {
          "$ref": "../common/digest.schema.json"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
