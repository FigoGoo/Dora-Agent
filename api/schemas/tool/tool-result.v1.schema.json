{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/tool/tool-result.v1.schema.json",
  "title": "ToolResult.v1",
  "type": "object",
  "required": [
    "schema_version",
    "tool_result_id",
    "tool_task_id",
    "status",
    "assets",
    "result_digest",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "tool_result.v1"
    },
    "tool_result_id": {
      "type": "string",
      "pattern": "^tres_[A-Za-z0-9_\\-]+$"
    },
    "tool_task_id": {
      "type": "string",
      "pattern": "^ttask_[A-Za-z0-9_\\-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "partially_succeeded",
        "failed"
      ]
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "../asset/generated-asset.v1.schema.json"
      }
    },
    "result_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
