{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/board/board-patch.v1.schema.json",
  "title": "BoardPatch.v1",
  "type": "object",
  "required": [
    "schema_version",
    "patch_id",
    "board_id",
    "base_version",
    "target_version",
    "operation",
    "actor",
    "idempotency_key",
    "payload",
    "patch_digest",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "board_patch.v1"
    },
    "patch_id": {
      "type": "string",
      "pattern": "^patch_[A-Za-z0-9_\\-]+$"
    },
    "board_id": {
      "type": "string",
      "pattern": "^board_[A-Za-z0-9_\\-]+$"
    },
    "base_version": {
      "type": "integer",
      "minimum": 0
    },
    "target_version": {
      "type": "integer",
      "minimum": 1
    },
    "operation": {
      "type": "string",
      "enum": [
        "add_element",
        "update_element",
        "remove_element",
        "reorder_elements",
        "replace_board",
        "approve_board"
      ]
    },
    "actor": {
      "type": "string",
      "enum": [
        "user",
        "agent",
        "graph"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "patch_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
