{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/credit/credit-freeze.v1.schema.json",
  "title": "CreditFreeze.v1",
  "type": "object",
  "required": [
    "schema_version",
    "credit_hold_id",
    "account_id",
    "account_scope",
    "run_id",
    "tool_plan_id",
    "tool_plan_digest",
    "status",
    "frozen_credits",
    "idempotency_key",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "credit_freeze.v1"
    },
    "credit_hold_id": {
      "type": "string",
      "pattern": "^chold_[A-Za-z0-9_\\-]+$"
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "account_scope": {
      "type": "string",
      "enum": [
        "personal",
        "enterprise"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_plan_id": {
      "type": "string",
      "pattern": "^tpl_[A-Za-z0-9_\\-]+$"
    },
    "tool_plan_digest": {
      "$ref": "../common/digest.schema.json"
    },
    "status": {
      "type": "string",
      "enum": [
        "frozen",
        "committed",
        "released",
        "failed"
      ]
    },
    "frozen_credits": {
      "type": "integer",
      "minimum": 0
    },
    "committed_credits": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "released_credits": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
