{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/credit/mock-payment.v1.schema.json",
  "title": "MockPayment.v1",
  "type": "object",
  "required": [
    "schema_version",
    "transaction_id",
    "order_id",
    "payment_result",
    "payment_status",
    "idempotency_key",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "mock_payment.v1"
    },
    "transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "payment_result": {
      "type": "string",
      "enum": [
        "success",
        "failed"
      ]
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "failed"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "mock_payment.v1",
      "transaction_id": "mock_txn_recharge_1000_success",
      "order_id": "ord_smoke_1000",
      "payment_result": "success",
      "payment_status": "paid",
      "idempotency_key": "usr_demo:mock_pay:ord_smoke_1000",
      "trace_id": "trace_recharge_smoke",
      "created_at": "2026-07-01T10:00:00Z"
    }
  ]
}
