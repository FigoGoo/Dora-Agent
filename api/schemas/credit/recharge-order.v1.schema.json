{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/credit/recharge-order.v1.schema.json",
  "title": "RechargeOrder.v1",
  "type": "object",
  "required": [
    "schema_version",
    "order_id",
    "account_id",
    "package_id",
    "points",
    "price_cents",
    "currency",
    "payment_provider",
    "payment_status",
    "idempotency_key",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "recharge_order.v1"
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "points": {
      "type": "integer",
      "minimum": 1
    },
    "price_cents": {
      "type": "integer",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "enum": [
        "CNY"
      ]
    },
    "payment_provider": {
      "type": "string",
      "enum": [
        "mock_payment"
      ]
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "failed"
      ]
    },
    "credit_lot_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "paid_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "payment_status": {
            "const": "paid"
          }
        }
      },
      "then": {
        "required": [
          "credit_lot_id",
          "paid_at"
        ]
      }
    }
  ],
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "recharge_order.v1",
      "order_id": "ord_smoke_1000",
      "account_id": "acct_personal_demo",
      "package_id": "pkg_1000_1m",
      "points": 1000,
      "price_cents": 9900,
      "currency": "CNY",
      "payment_provider": "mock_payment",
      "payment_status": "paid",
      "credit_lot_id": "lot_recharge_1000",
      "idempotency_key": "usr_demo:recharge:pkg_1000_1m",
      "trace_id": "trace_recharge_smoke",
      "created_at": "2026-07-01T10:00:00Z",
      "paid_at": "2026-07-01T10:00:00Z"
    }
  ]
}
