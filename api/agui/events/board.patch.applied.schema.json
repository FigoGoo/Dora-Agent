{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/board.patch.applied.schema.json",
  "title": "board.patch.applied.v1",
  "type": "object",
  "required": [
    "board_id",
    "patch_id",
    "base_version",
    "target_version",
    "operation",
    "patch_digest"
  ],
  "properties": {
    "board_id": {
      "type": "string"
    },
    "patch_id": {
      "type": "string"
    },
    "base_version": {
      "type": "integer",
      "minimum": 0
    },
    "target_version": {
      "type": "integer",
      "minimum": 1
    },
    "operation": {
      "type": "string"
    },
    "patch_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    }
  },
  "additionalProperties": false
}
