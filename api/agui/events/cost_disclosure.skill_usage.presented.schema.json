{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/cost_disclosure.skill_usage.presented.schema.json",
  "title": "cost_disclosure.skill_usage.presented.v1",
  "type": "object",
  "required": [
    "disclosure_id",
    "usage_id",
    "listing_id",
    "skill_usage_fee",
    "tool_generation_fee_notice",
    "confirmation_required"
  ],
  "properties": {
    "disclosure_id": {
      "type": "string"
    },
    "usage_id": {
      "type": "string"
    },
    "listing_id": {
      "type": "string"
    },
    "skill_usage_fee": {
      "type": "object",
      "required": [
        "points",
        "charge_timing",
        "refund_policy_summary"
      ],
      "properties": {
        "points": {
          "type": "integer",
          "minimum": 0
        },
        "charge_timing": {
          "type": "string"
        },
        "refund_policy_summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "tool_generation_fee_notice": {
      "type": "string"
    },
    "creator_data_visibility_summary": {
      "type": "string"
    },
    "confirmation_required": {
      "type": "boolean",
      "const": true
    },
    "skill_usage_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    },
    "payload_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    }
  },
  "additionalProperties": false
}
