{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/graph.node.updated.schema.json",
  "title": "graph.node.updated.v1",
  "type": "object",
  "required": [
    "graph_plan_id",
    "node_id",
    "node_type",
    "node_status",
    "progress"
  ],
  "properties": {
    "graph_plan_id": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "node_type": {
      "type": "string"
    },
    "node_status": {
      "type": "string"
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "output_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    }
  },
  "additionalProperties": false
}
