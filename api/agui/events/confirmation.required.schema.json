{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/confirmation.required.schema.json",
  "title": "confirmation.required.v1",
  "type": "object",
  "required": [
    "confirmation_id",
    "confirmation_type",
    "title",
    "summary",
    "digest",
    "expires_at",
    "actions"
  ],
  "properties": {
    "confirmation_id": {
      "type": "string"
    },
    "confirmation_type": {
      "type": "string",
      "enum": [
        "skill_usage",
        "tool_generation",
        "combined_cost",
        "safety",
        "resume"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action",
          "label"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "confirm",
              "reject",
              "modify"
            ]
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "payload_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    }
  },
  "additionalProperties": false
}
