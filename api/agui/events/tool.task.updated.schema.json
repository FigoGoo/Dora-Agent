{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/tool.task.updated.schema.json",
  "title": "tool.task.updated.v1",
  "type": "object",
  "required": [
    "tool_task_id",
    "tool_plan_id",
    "status",
    "progress"
  ],
  "properties": {
    "tool_task_id": {
      "type": "string"
    },
    "tool_plan_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "output_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
