{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/board.snapshot.updated.schema.json",
  "title": "board.snapshot.updated.v1",
  "type": "object",
  "required": [
    "board_id",
    "board_version",
    "board_status",
    "board_digest",
    "changed_element_ids",
    "snapshot_required"
  ],
  "properties": {
    "board_id": {
      "type": "string"
    },
    "board_version": {
      "type": "integer",
      "minimum": 1
    },
    "board_status": {
      "type": "string"
    },
    "board_digest": {
      "$ref": "../../schemas/common/digest.schema.json"
    },
    "changed_element_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "snapshot_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
