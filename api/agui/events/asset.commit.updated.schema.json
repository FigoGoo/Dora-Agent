{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/events/asset.commit.updated.schema.json",
  "title": "asset.commit.updated.v1",
  "type": "object",
  "required": [
    "tool_task_id",
    "commit_status",
    "committed_asset_ids",
    "failed_asset_count"
  ],
  "properties": {
    "tool_task_id": {
      "type": "string"
    },
    "commit_status": {
      "type": "string",
      "enum": [
        "committed",
        "partially_committed",
        "failed"
      ]
    },
    "committed_asset_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_asset_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
