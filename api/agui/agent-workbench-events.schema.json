        "project_id",
        "session_id",
        "started_at"
      ],
      "properties": {
        "run_status": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "Payload_agent_run_completed": {
      "type": "object",
