{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dora.local/schemas/agui/agent-workbench-events.schema.json",
  "title": "AGUIEventEnvelope.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "payload_schema_version",
    "project_id",
    "session_id",
    "run_id",
    "seq",
    "created_at",
    "dedupe_key",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_\\-]+$"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "schema_version": {
      "const": "agui.event.v1"
    },
    "payload_schema_version": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+\\.v[0-9]+$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "space_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor_user_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "user_visible",
        "internal_summary",
        "admin_only"
      ],
      "default": "user_visible"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "payload_digest": {
      "$ref": "../schemas/common/digest.schema.json"
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "evt_router_001",
      "event_type": "creative.router.decided",
      "schema_version": "agui.event.v1",
      "payload_schema_version": "creative.router.decided.v1",
      "project_id": "proj_001",
      "space_id": "space_001",
      "actor_user_id": "user_001",
      "session_id": "sess_001",
      "run_id": "run_001",
      "seq": 2,
      "created_at": "2026-07-01T00:00:02Z",
      "visibility": "user_visible",
      "dedupe_key": "run_001:creative.router.decided:2",
      "payload_digest": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "trace_id": "trc_001",
      "payload": {}
    }
  ]
}
