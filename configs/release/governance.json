{
  "schema_version": "release_governance_manifest.v1",
  "status": "active",
  "owner": [
    "运维发布责任域",
    "文档与契约责任域",
    "测试与验收责任域"
  ],
  "updated_at": "2026-07-01",
  "release_policy": {
    "default_provider_mode": "fake",
    "all_new_feature_flags_default_off": true,
    "true_provider_requires": [
      "active-contract-gate",
      "development-ci-gate",
      "release-full-http-smoke",
      "release-browser-smoke",
      "release-http-service-e2e",
      "release-governance-gate",
      "manual_release_approval"
    ]
  },
  "feature_flags": [
    {
      "flag": "agent_runtime_v2",
      "default": "off",
      "controls": [
        "agent router v2 entrypoint",
        "graph and board runtime",
        "AG-UI replay writer"
      ],
      "rollback_actions": [
        "close agent_runtime_v2",
        "stop new run creation on v2 routes",
        "keep AG-UI replay readable for existing runs"
      ]
    },
    {
      "flag": "tool_generation_v2",
      "default": "off",
      "controls": [
        "ToolPlan confirmation",
        "provider worker",
        "asset commit worker",
        "credit hold release worker"
      ],
      "rollback_actions": [
        "close tool_generation_v2",
        "stop tool:task:requested consumption",
        "release uncharged credit holds idempotently"
      ]
    },
    {
      "flag": "marketplace_v2",
      "default": "off",
      "controls": [
        "skill marketplace",
        "skill installation",
        "SkillUsageRecord pre-create",
        "settlement hold"
      ],
      "rollback_actions": [
        "close marketplace_v2",
        "block new paid skill installations",
        "preserve historical run and usage replay"
      ]
    },
    {
      "flag": "creator_portal_v2",
      "default": "off",
      "controls": [
        "creator draft",
        "creator submit review",
        "creator release history"
      ],
      "rollback_actions": [
        "close creator_portal_v2",
        "block draft submission",
        "keep creator records read-only"
      ]
    },
    {
      "flag": "admin_governance_v2",
      "default": "off",
      "controls": [
        "skill review",
        "listing suspension",
        "refund reverse",
        "settlement payout confirmation"
      ],
      "rollback_actions": [
        "close admin_governance_v2",
        "block new approval mutations",
        "keep governance queries read-only"
      ]
    }
  ],
  "release_gates": [
    {
      "gate": "Contract Gate",
      "phase": "pre_merge",
      "command": "make active-contract-gate",
      "required": true,
      "artifacts": [
        "contract validator log"
      ],
      "blocking_conditions": [
        "schema validation failure",
        "OpenAPI parse failure",
        "Thrift or migration static guard failure"
      ]
    },
    {
      "gate": "Migration Gate",
      "phase": "before_test_deploy",
      "command": "PostgreSQL dry-run and down-test",
      "required": true,
      "artifacts": [
        "migration replay report"
      ],
      "blocking_conditions": [
        "migration cannot replay",
        "down migration cannot rollback",
        "data compatibility check failure"
      ]
    },
    {
      "gate": "Fixture Gate",
      "phase": "before_e2e",
      "command": "python3 tests/contract/validate_release_e2e_gates.py",
      "required": true,
      "artifacts": [
        "fixture validation log"
      ],
      "blocking_conditions": [
        "missing E2E fixture",
        "missing fake provider behavior",
        "missing release gate artifact"
      ]
    },
    {
      "gate": "Service E2E Gate",
      "phase": "before_release",
      "command": "go test ./services/business/internal/e2e/release",
      "required": true,
      "artifacts": [
        "business service-level E2E log"
      ],
      "blocking_conditions": [
        "ToolPlan, Credit, Asset, Marketplace, SkillUsage or Settlement path failure"
      ]
    },
    {
      "gate": "Agent / Business HTTP Gate",
      "phase": "before_release",
      "command": "go test ./services/agent/internal/e2e/release ./services/business/internal/e2e/release",
      "required": true,
      "artifacts": [
        "agent and business HTTP smoke log"
      ],
      "blocking_conditions": [
        "health check failure",
        "AG-UI replay failure",
        "Redis stream dedupe failure",
        "Agent or Business process startup failure"
      ]
    },
    {
      "gate": "Local Full HTTP Service Gate",
      "phase": "before_release",
      "command": "make release-full-http-smoke",
      "required": true,
      "artifacts": [
        "local full HTTP service smoke log"
      ],
      "blocking_conditions": [
        "Business HTTP login failure",
        "Business RPC failure",
        "Agent run failure",
        "AG-UI replay failure"
      ]
    },
    {
      "gate": "Browser Smoke Gate",
      "phase": "before_release",
      "command": "make release-browser-smoke",
      "required": true,
      "artifacts": [
        "browser smoke log"
      ],
      "blocking_conditions": [
        "marketplace installation UI failure",
        "creator submission UI failure",
        "admin settlement governance UI failure"
      ]
    },
    {
      "gate": "Fake Provider Gate",
      "phase": "e2e",
      "command": "python3 tests/contract/validate_release_e2e_gates.py",
      "required": true,
      "artifacts": [
        "fake provider behavior validation log"
      ],
      "blocking_conditions": [
        "deterministic success missing",
        "partial failure missing",
        "timeout or idempotency behavior missing"
      ]
    },
    {
      "gate": "Test Environment HTTP Service Gate",
      "phase": "before_true_provider",
      "command": "make release-http-service-e2e",
      "required": true,
      "artifacts": [
        "tests/reports/release-http-service-e2e-report.md"
      ],
      "blocking_conditions": [
        "Business or Agent health failure",
        "login failure",
        "Agent session or run failure",
        "RouterDecision missing",
        "AG-UI replay failure",
        "report status is not passed"
      ]
    },
    {
      "gate": "Release Governance Manifest Gate",
      "phase": "pre_merge",
      "command": "make release-governance-gate",
      "required": true,
      "artifacts": [
        "configs/release/governance.json",
        "release governance validation log"
      ],
      "blocking_conditions": [
        "feature flag default is not off",
        "missing rollback action",
        "missing observability threshold",
        "missing data repair case"
      ]
    },
    {
      "gate": "Build Gate",
      "phase": "before_release",
      "command": "service and frontend build commands",
      "required": true,
      "artifacts": [
        "build artifacts"
      ],
      "blocking_conditions": [
        "any service or frontend build fails"
      ]
    },
    {
      "gate": "Release Gate",
      "phase": "gray_release",
      "command": "health check, key API/RPC/AG-UI smoke and manual release approval",
      "required": true,
      "artifacts": [
        "release record",
        "approval record"
      ],
      "blocking_conditions": [
        "missing metric",
        "missing trace",
        "missing rollback owner",
        "missing audit record"
      ]
    }
  ],
  "observability_metrics": [
    {
      "metric": "agent_run_success_rate",
      "kind": "ratio",
      "owner": "Agent Runtime",
      "labels": [
        "tenant_id",
        "run_intent",
        "model_provider"
      ],
      "blocking_threshold": "gray_drop_gt_2_percent_or_lt_99_percent",
      "required_trace_fields": [
        "trace_id",
        "session_id",
        "run_id"
      ]
    },
    {
      "metric": "router_decision_latency_ms",
      "kind": "histogram",
      "owner": "Agent Runtime",
      "labels": [
        "tenant_id",
        "run_intent",
        "route"
      ],
      "blocking_threshold": "p95_gt_1500_ms",
      "required_trace_fields": [
        "trace_id",
        "session_id",
        "run_id"
      ]
    },
    {
      "metric": "board_patch_replay_error_count",
      "kind": "counter",
      "owner": "Agent Runtime",
      "labels": [
        "tenant_id",
        "board_id"
      ],
      "blocking_threshold": "increase_gt_0_in_10m",
      "required_trace_fields": [
        "trace_id",
        "run_id",
        "board_id"
      ]
    },
    {
      "metric": "graph_resume_failure_count",
      "kind": "counter",
      "owner": "Agent Runtime",
      "labels": [
        "tenant_id",
        "graph_id"
      ],
      "blocking_threshold": "increase_gt_0_in_10m",
      "required_trace_fields": [
        "trace_id",
        "run_id",
        "graph_id"
      ]
    },
    {
      "metric": "tool_task_success_rate",
      "kind": "ratio",
      "owner": "Tool Runtime",
      "labels": [
        "tenant_id",
        "provider_id",
        "tool_type"
      ],
      "blocking_threshold": "gray_drop_gt_2_percent_or_lt_98_percent",
      "required_trace_fields": [
        "trace_id",
        "run_id",
        "tool_plan_id",
        "tool_task_id"
      ]
    },
    {
      "metric": "credit_freeze_leak_count",
      "kind": "gauge",
      "owner": "Credit Service",
      "labels": [
        "tenant_id",
        "hold_reason"
      ],
      "blocking_threshold": "gt_0",
      "required_trace_fields": [
        "trace_id",
        "credit_hold_id"
      ]
    },
    {
      "metric": "skill_usage_charge_error_count",
      "kind": "counter",
      "owner": "Marketplace",
      "labels": [
        "tenant_id",
        "skill_id",
        "usage_status"
      ],
      "blocking_threshold": "gt_0",
      "required_trace_fields": [
        "trace_id",
        "run_id",
        "usage_id",
        "credit_hold_id"
      ]
    },
    {
      "metric": "marketplace_install_failure_count",
      "kind": "counter",
      "owner": "Marketplace",
      "labels": [
        "tenant_id",
        "installation_scope",
        "upgrade_strategy"
      ],
      "blocking_threshold": "increase_gt_5_percent_in_10m",
      "required_trace_fields": [
        "trace_id",
        "installation_id"
      ]
    },
    {
      "metric": "settlement_reverse_count",
      "kind": "counter",
      "owner": "Settlement",
      "labels": [
        "tenant_id",
        "creator_id",
        "reverse_reason"
      ],
      "blocking_threshold": "increase_requires_manual_review",
      "required_trace_fields": [
        "trace_id",
        "usage_id",
        "settlement_id"
      ]
    }
  ],
  "rollback_steps": [
    {
      "order": 1,
      "action": "close feature flags",
      "details": [
        "close marketplace_v2",
        "close tool_generation_v2",
        "close agent_runtime_v2",
        "close creator_portal_v2",
        "close admin_governance_v2"
      ]
    },
    {
      "order": 2,
      "action": "stop worker stream consumption",
      "details": [
        "stop tool:task:requested",
        "stop asset:commit:requested",
        "stop credit:hold:release_requested"
      ]
    },
    {
      "order": 3,
      "action": "release uncharged credit hold",
      "details": [
        "release every credit hold that is not charged or committed",
        "use credit_hold_id as idempotency key"
      ]
    },
    {
      "order": 4,
      "action": "preserve immutable business facts",
      "details": [
        "preserve generated assets",
        "preserve charged ledger",
        "preserve SkillUsageRecord",
        "preserve Settlement"
      ]
    },
    {
      "order": 5,
      "action": "keep AG-UI replay compatible",
      "details": [
        "continue serving AG-UI replay for historical runs",
        "dedupe replay events by dedupe_key"
      ]
    },
    {
      "order": 6,
      "action": "write rollback audit",
      "details": [
        "record operator",
        "record trace_id",
        "record reason",
        "record affected_run_ids",
        "record affected_hold_ids"
      ]
    }
  ],
  "data_repair_cases": [
    {
      "case": "tool_task_terminal_failure_hold_not_released",
      "trigger": "ToolTask reaches terminal failure and credit hold remains frozen",
      "repair": "release by credit_hold_id idempotently and write audit",
      "idempotency_key": "credit_hold_id",
      "audit_required": true
    },
    {
      "case": "duplicate_provider_callback",
      "trigger": "provider callback has an already consumed dedupe_key",
      "repair": "ignore duplicate callback and do not submit asset again",
      "idempotency_key": "dedupe_key",
      "audit_required": true
    },
    {
      "case": "skill_usage_charged_but_settlement_missing",
      "trigger": "SkillUsageRecord is charged and settlement hold is missing",
      "repair": "create pending_hold by usage_id idempotently",
      "idempotency_key": "usage_id",
      "audit_required": true
    },
    {
      "case": "settlement_reversed_but_creator_hold_releasable",
      "trigger": "settlement is reversed and creator hold is still releasable",
      "repair": "freeze settlement and require manual review",
      "idempotency_key": "settlement_id",
      "audit_required": true
    },
    {
      "case": "listing_suspended_but_new_installation_created",
      "trigger": "new installation is created after listing suspension",
      "repair": "revoke installation, preserve audit, keep historical run unchanged",
      "idempotency_key": "installation_id",
      "audit_required": true
    }
  ],
  "required_audit_fields": [
    "operator",
    "trace_id",
    "reason",
    "affected_run_ids",
    "affected_hold_ids"
  ]
}
