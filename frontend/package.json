{
  "name": "doraigc-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3200",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e:w0": "playwright test --config=playwright.config.js --grep-invert '@w1-skill|@w1-real-review'",
    "test:e2e:w1": "playwright test --config=playwright.config.js --grep @w1-skill",
    "test:e2e:w1-real-review": "node ./scripts/require-w1-real-review-env.mjs && playwright test --config=playwright.config.js --grep @w1-real-review"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
