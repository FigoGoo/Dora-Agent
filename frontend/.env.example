# 前端开发代理只配置本地服务目标，不包含认证凭据或业务 Secret。
VITE_BUSINESS_API_TARGET=http://localhost:18081
VITE_AGENT_API_TARGET=http://localhost:18082
# 一键本地 MVP Profile。启用时必须保持下方隔离开关为 false；未知值会失败关闭。
VITE_DORA_RUNTIME_PROFILE=
# 六工具媒体扩展；只能与上方统一 Profile 同时精确启用，未知/单独启用均失败关闭。
VITE_DORA_MEDIA_RUNTIME_PROFILE=
# 仅在 Business 与 Agent 使用同一个 local Preview 开关启动时设为 true；服务端仍独立失败关闭。
# true 时 QuickCreate 的 initial_prompt 延后为 null，首页目标只在前端进程内一次性交给 Workspace Preview 表单。
VITE_DORA_PLAN_SPEC_PREVIEW_ENABLED=false
# 素材分析隔离 Profile 兼容开关；统一 Profile 会直接派生该能力。
VITE_DORA_ANALYZE_MATERIALS_RUNTIME_ENABLED=false
# 仅在 Business/Agent 同时启用 plan_storyboard.runtime.v2preview1 时设为 true；关闭时仍可只读恢复已有安全 Card。
VITE_DORA_PLAN_STORYBOARD_RUNTIME_ENABLED=false
VITE_DORA_WRITE_PROMPTS_RUNTIME_ENABLED=false

# W0/W1 Playwright 冒烟从进程环境读取账号，禁止在该文件中保存真实凭据。
# DORA_E2E_USER_EMAIL=
# DORA_E2E_USER_PASSWORD=
# DORA_E2E_REVIEWER_EMAIL=
# DORA_E2E_REVIEWER_PASSWORD=
# DORA_E2E_BASE_URL=http://127.0.0.1:3200
# DORA_E2E_BUSINESS_API_TARGET=http://127.0.0.1:18081
