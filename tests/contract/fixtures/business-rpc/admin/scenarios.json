{
  "domain": "admin",
  "scenarios": [
    {
      "case_id": "admin_create_admin_success",
      "service": "AdminService",
      "method": "CreateAdmin",
      "scenario": "create_admin_success",
      "request_hash": "sha256:admin-create-admin-request",
      "audit_expectation": {
        "action": "AdminService.CreateAdmin",
        "trace_id": "trace_admin_create_admin_success",
        "result": "succeeded"
      },
      "request": {
        "admin_auth": {
          "actor_user_id": "usr_admin_root",
          "login_identity_type": "ADMIN",
          "admin_id": "adm_root"
        },
        "request_meta": {
          "request_id": "req_admin_create_admin_success",
          "trace_id": "trace_admin_create_admin_success",
          "source": "business_admin_http",
          "idempotency_key": "idem_admin_create_admin_success"
        },
        "email_hash": "sha256:admin-email-hash",
        "display_name": "Ops Admin",
        "role": "operator"
      },
      "assertions": [
        "backend RPC requires login_identity_type=ADMIN",
        "plain email and password are not part of the RPC response"
      ],
      "response": {
        "admin": {
          "admin_id": "adm_operator_1001",
          "email_masked": "o***@example.com",
          "display_name": "Ops Admin",
          "role": "operator",
          "status": "active",
          "must_rotate_password": true,
          "created_at": "2026-06-28T12:00:00Z"
        }
      }
    },
    {
      "case_id": "admin_disable_admin_success",
      "service": "AdminService",
      "method": "DisableAdmin",
      "scenario": "disable_admin_success",
      "request_hash": "sha256:admin-disable-admin-request",
      "audit_expectation": {
        "action": "AdminService.DisableAdmin",
        "trace_id": "trace_admin_disable_admin_success",
        "result": "succeeded"
      },
      "request": {
        "admin_auth": {
          "actor_user_id": "usr_admin_root",
          "login_identity_type": "ADMIN",
          "admin_id": "adm_root"
        },
        "request_meta": {
          "request_id": "req_admin_disable_admin_success",
          "trace_id": "trace_admin_disable_admin_success",
          "source": "business_admin_http",
          "idempotency_key": "idem_admin_disable_admin_success"
        },
        "target_admin_id": "adm_operator_1001",
        "reason": "operator offboarded"
      },
      "assertions": [
        "root admin can disable a non-root admin",
        "operation writes admin audit"
      ],
      "response": {
        "admin": {
          "admin_id": "adm_operator_1001",
          "email_masked": "o***@example.com",
          "display_name": "Ops Admin",
          "role": "operator",
          "status": "disabled",
          "must_rotate_password": false,
          "created_at": "2026-06-28T12:00:00Z"
        }
      }
    },
    {
      "case_id": "admin_preview_user_status_success",
      "service": "UserAdminService",
      "method": "PreviewSetUserStatus",
      "scenario": "preview_user_status_success",
      "request": {
        "admin_auth": {
          "actor_user_id": "usr_admin_root",
          "login_identity_type": "ADMIN",
          "admin_id": "adm_root"
        },
        "request_meta": {
          "request_id": "req_admin_preview_user_status_success",
          "trace_id": "trace_admin_preview_user_status_success",
          "source": "business_admin_http"
        },
        "target_user_id": "usr_1002",
        "target_status": "disabled",
        "reason": "policy violation"
      },
      "assertions": [
        "preview returns affected user and short lived preview token",
        "ordinary user token is rejected with PERMISSION_DENIED"
      ],
      "response": {
        "preview_token": "user_status_preview_token_1002",
        "user": {
          "user_id": "usr_1002",
          "display_name": "Seed User",
          "status": "active",
          "disabled_reason": ""
        },
        "target_status": "disabled",
        "expires_at": "2026-06-28T13:00:00Z"
      }
    },
    {
      "case_id": "admin_confirm_user_status_success",
      "service": "UserAdminService",
      "method": "ConfirmSetUserStatus",
      "scenario": "confirm_user_status_success",
      "request_hash": "sha256:admin-confirm-user-status-request",
      "audit_expectation": {
        "action": "UserAdminService.ConfirmSetUserStatus",
        "trace_id": "trace_admin_confirm_user_status_success",
        "result": "succeeded"
      },
      "request": {
        "admin_auth": {
          "actor_user_id": "usr_admin_root",
          "login_identity_type": "ADMIN",
          "admin_id": "adm_root"
        },
        "request_meta": {
          "request_id": "req_admin_confirm_user_status_success",
          "trace_id": "trace_admin_confirm_user_status_success",
          "source": "business_admin_http",
          "idempotency_key": "idem_admin_confirm_user_status_success"
        },
        "target_user_id": "usr_1002",
        "preview_token": "user_status_preview_token_1002"
      },
      "assertions": [
        "confirm rechecks preview token, admin identity and current user state",
        "disabled users are rejected by Agent-facing auth resolution"
      ],
      "response": {
        "user": {
          "user_id": "usr_1002",
          "display_name": "Seed User",
          "status": "disabled",
          "disabled_reason": "policy violation"
        }
      }
    }
  ]
}
